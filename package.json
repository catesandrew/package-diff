{
  "name": "package-diff",
  "version": "0.1.0",
  "description": "CLI tool to inspect dependency changes between git commits",
  "author": "Andrew Cates",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/catesandrew/package-diff"
  },
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "bin": {
    "package-diff": "bin/package-diff",
    "whatsdiff": "bin/package-diff"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "build:exe": "bun build ./src/cli.ts --compile --outfile ./dist/package-diff"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "changelog-parser": "^3.0.1",
    "commander": "^12.1.0",
    "ink": "^5.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "semver": "^7.6.3",
    "yaml": "^2.5.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/semver": "^7.7.1",
    "react-devtools-core": "^4.28.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
