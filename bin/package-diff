#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
# Import tsx from this package so the command works when run from other repos.
exec node --import "${PROJECT_ROOT}/node_modules/tsx/dist/esm/index.mjs" "${PROJECT_ROOT}/src/cli.ts" "$@"
